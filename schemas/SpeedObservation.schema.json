{
  "$defs": {
    "Producer": {
      "additionalProperties": false,
      "description": "Provenance for what produced an observation (model/heuristic/rule).",
      "properties": {
        "kind": {
          "$ref": "#/$defs/ProducerKind"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "name",
        "version",
        "kind"
      ],
      "title": "Producer",
      "type": "object"
    },
    "ProducerKind": {
      "description": "What kind of component produced an observation (provenance).",
      "enum": [
        "model",
        "heuristic",
        "rule",
        "tracker",
        "calibration"
      ],
      "title": "ProducerKind",
      "type": "string"
    },
    "SpeedUnit": {
      "description": "Units for reported speed observations.",
      "enum": [
        "km_per_h",
        "m_per_s"
      ],
      "title": "SpeedUnit",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Ground-plane speed with explicit uncertainty (v +/- sigma; §17).",
  "properties": {
    "camera_id": {
      "minLength": 1,
      "title": "Camera Id",
      "type": "string"
    },
    "confidence": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Confidence"
    },
    "measurement_zone_id": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Measurement Zone Id"
    },
    "obs_type": {
      "const": "speed",
      "default": "speed",
      "title": "Obs Type",
      "type": "string"
    },
    "observation_id": {
      "minLength": 1,
      "title": "Observation Id",
      "type": "string"
    },
    "producer": {
      "$ref": "#/$defs/Producer"
    },
    "sample_count": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Sample Count"
    },
    "speed_sigma": {
      "minimum": 0.0,
      "title": "Speed Sigma",
      "type": "number"
    },
    "speed_value": {
      "minimum": 0.0,
      "title": "Speed Value",
      "type": "number"
    },
    "timestamp": {
      "format": "date-time",
      "title": "Timestamp",
      "type": "string"
    },
    "track_id": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Track Id"
    },
    "unit": {
      "$ref": "#/$defs/SpeedUnit"
    }
  },
  "required": [
    "observation_id",
    "camera_id",
    "timestamp",
    "producer",
    "speed_value",
    "speed_sigma",
    "unit"
  ],
  "title": "SpeedObservation",
  "type": "object"
}
