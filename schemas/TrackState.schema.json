{
  "$defs": {
    "BoundingBox": {
      "additionalProperties": false,
      "description": "Axis-aligned image-space box in pixel coordinates (top-left origin).",
      "properties": {
        "x1": {
          "minimum": 0.0,
          "title": "X1",
          "type": "number"
        },
        "x2": {
          "minimum": 0.0,
          "title": "X2",
          "type": "number"
        },
        "y1": {
          "minimum": 0.0,
          "title": "Y1",
          "type": "number"
        },
        "y2": {
          "minimum": 0.0,
          "title": "Y2",
          "type": "number"
        }
      },
      "required": [
        "x1",
        "y1",
        "x2",
        "y2"
      ],
      "title": "BoundingBox",
      "type": "object"
    },
    "ModelRef": {
      "additionalProperties": false,
      "description": "Reference to a model/weights version (metadata only; no loading).",
      "properties": {
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "title": "Version",
          "type": "string"
        },
        "weights_hash": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Weights Hash"
        }
      },
      "required": [
        "name",
        "version"
      ],
      "title": "ModelRef",
      "type": "object"
    },
    "ObjectClass": {
      "description": "Detector/tracker object classes (architecture-review §5 shared core).",
      "enum": [
        "motorcycle",
        "car",
        "bus",
        "truck",
        "auto_rickshaw",
        "bicycle",
        "person",
        "license_plate"
      ],
      "title": "ObjectClass",
      "type": "string"
    },
    "TrackStatus": {
      "description": "Tracker-owned lifecycle of a single track.",
      "enum": [
        "tentative",
        "active",
        "lost",
        "removed"
      ],
      "title": "TrackStatus",
      "type": "string"
    },
    "Velocity": {
      "additionalProperties": false,
      "description": "Image-space motion vector, pixels per second (data only).",
      "properties": {
        "vx": {
          "title": "Vx",
          "type": "number"
        },
        "vy": {
          "title": "Vy",
          "type": "number"
        }
      },
      "required": [
        "vx",
        "vy"
      ],
      "title": "Velocity",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "State of one tracked entity at a point in time.\n\n``tainted`` records the ID-switch guard from architecture-review §13\n(tainted tracks may abstain but never confirm); enforcement of that rule\nis Phase 1 behaviour, not part of this contract.",
  "properties": {
    "bbox": {
      "$ref": "#/$defs/BoundingBox"
    },
    "camera_id": {
      "minLength": 1,
      "title": "Camera Id",
      "type": "string"
    },
    "confidence": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Confidence"
    },
    "frame_index": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Frame Index"
    },
    "object_class": {
      "$ref": "#/$defs/ObjectClass"
    },
    "status": {
      "$ref": "#/$defs/TrackStatus"
    },
    "tainted": {
      "default": false,
      "title": "Tainted",
      "type": "boolean"
    },
    "timestamp": {
      "format": "date-time",
      "title": "Timestamp",
      "type": "string"
    },
    "track_id": {
      "minLength": 1,
      "title": "Track Id",
      "type": "string"
    },
    "tracker": {
      "anyOf": [
        {
          "$ref": "#/$defs/ModelRef"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "velocity": {
      "anyOf": [
        {
          "$ref": "#/$defs/Velocity"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "required": [
    "track_id",
    "camera_id",
    "timestamp",
    "object_class",
    "bbox",
    "status"
  ],
  "title": "TrackState",
  "type": "object"
}
