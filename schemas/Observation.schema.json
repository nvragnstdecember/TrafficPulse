    "StationaryObservation": {
      "additionalProperties": false,
      "description": "Whether a track is stationary, with optional dwell (illegal stopping).",
      "properties": {
        "camera_id": {
          "minLength": 1,
          "title": "Camera Id",
          "type": "string"
        },
        "confidence": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        },
        "dwell_seconds": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Dwell Seconds"
        },
        "is_stationary": {
          "title": "Is Stationary",
          "type": "boolean"
        },
        "obs_type": {
          "const": "stationary",
          "default": "stationary",
          "title": "Obs Type",
          "type": "string"
        },
        "observation_id": {
          "minLength": 1,
          "title": "Observation Id",
          "type": "string"
        },
        "producer": {
          "$ref": "#/$defs/Producer"
        },
        "speed_estimate": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Speed Estimate"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "track_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Track Id"
        }
