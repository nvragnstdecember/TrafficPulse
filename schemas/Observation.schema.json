{
  "$defs": {
    "HeadingVsLaneObservation": {
      "additionalProperties": false,
      "description": "Track heading relative to a lane's legal direction (wrong-way).",
      "properties": {
        "camera_id": {
          "minLength": 1,
          "title": "Camera Id",
          "type": "string"
        },
        "confidence": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        },
        "deviation_degrees": {
          "maximum": 180.0,
          "minimum": 0.0,
          "title": "Deviation Degrees",
          "type": "number"
        },
        "heading_degrees": {
          "maximum": 360.0,
          "minimum": 0.0,
          "title": "Heading Degrees",
          "type": "number"
        },
        "is_contradiction": {
          "title": "Is Contradiction",
          "type": "boolean"
        },
        "lane_id": {
          "minLength": 1,
          "title": "Lane Id",
          "type": "string"
        },
        "legal_heading_degrees": {
          "anyOf": [
            {
              "maximum": 360.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Legal Heading Degrees"
        },
        "obs_type": {
          "const": "heading_vs_lane",
          "default": "heading_vs_lane",
          "title": "Obs Type",
          "type": "string"
        },
        "observation_id": {
          "minLength": 1,
          "title": "Observation Id",
          "type": "string"
        },
        "producer": {
          "$ref": "#/$defs/Producer"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "track_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Track Id"
        }
      },
      "required": [
        "observation_id",
        "camera_id",
        "timestamp",
        "producer",
        "lane_id",
        "heading_degrees",
        "deviation_degrees",
        "is_contradiction"
      ],
      "title": "HeadingVsLaneObservation",
      "type": "object"
    },
    "HelmetState": {
      "description": "Four-label helmet ontology (architecture-review §5e, §12).\n\nThe rule-layer mapping (turban -> exempt, uncertain -> abstain) is U3's\nresponsibility and is deliberately not encoded in the contracts.",
      "enum": [
        "helmet",
        "no_helmet",
        "turban",
        "uncertain"
      ],
      "title": "HelmetState",
      "type": "string"
    },
    "HelmetStateObservation": {
      "additionalProperties": false,
      "description": "Per-rider-slot helmet state.\n\nCarries the four-label ontology {helmet, no_helmet, turban, uncertain}\nrequired later by U3. The rule-layer mapping (turban -> exempt,\nuncertain -> abstain) is U3's responsibility and is not encoded here.",
      "properties": {
        "camera_id": {
          "minLength": 1,
          "title": "Camera Id",
          "type": "string"
        },
        "confidence": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        },
        "crop_height_px": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Crop Height Px"
        },
        "helmet_state": {
          "$ref": "#/$defs/HelmetState"
        },
        "obs_type": {
          "const": "helmet_state",
          "default": "helmet_state",
          "title": "Obs Type",
          "type": "string"
        },
        "observation_id": {
          "minLength": 1,
          "title": "Observation Id",
          "type": "string"
        },
        "producer": {
          "$ref": "#/$defs/Producer"
        },
        "rider_slot": {
          "anyOf": [
            {
              "$ref": "#/$defs/RiderSlot"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "track_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Track Id"
        }
      },
      "required": [
        "observation_id",
        "camera_id",
        "timestamp",
        "producer",
        "helmet_state"
      ],
      "title": "HelmetStateObservation",
      "type": "object"
    },
    "InZoneObservation": {
