            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        },
        "motorcycle_track_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Motorcycle Track Id"
        },
        "obs_type": {
          "const": "rider_count",
          "default": "rider_count",
          "title": "Obs Type",
          "type": "string"
        },
        "observation_id": {
          "minLength": 1,
          "title": "Observation Id",
          "type": "string"
        },
        "producer": {
          "$ref": "#/$defs/Producer"
        },
        "rider_count": {
          "minimum": 0,
          "title": "Rider Count",
          "type": "integer"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "track_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Track Id"
        }
      },
      "required": [
        "observation_id",
        "camera_id",
        "timestamp",
        "producer",
        "rider_count"
      ],
      "title": "RiderCountObservation",
      "type": "object"
    },
    "RiderSlot": {
      "description": "Ordered rider slot on a motorcycle (architecture-review §5e).",
      "enum": [
        "driver",
        "pillion",
        "third",
        "unknown"
      ],
      "title": "RiderSlot",
      "type": "string"
    },
    "SignalState": {
      "description": "Traffic-signal states (architecture-review §5b).",
      "enum": [
        "red",
        "amber",
        "green",
        "off",
        "unknown"
      ],
      "title": "SignalState",
      "type": "string"
    },
    "SignalStateObservation": {
      "additionalProperties": false,
