  "discriminator": {
    "mapping": {
      "heading_vs_lane": "#/$defs/HeadingVsLaneObservation",
      "helmet_state": "#/$defs/HelmetStateObservation",
      "in_zone": "#/$defs/InZoneObservation",
      "rider_count": "#/$defs/RiderCountObservation",
      "signal_state": "#/$defs/SignalStateObservation",
      "speed": "#/$defs/SpeedObservation",
      "stationary": "#/$defs/StationaryObservation"
    },
    "propertyName": "obs_type"
  },
  "oneOf": [
    {
      "$ref": "#/$defs/InZoneObservation"
    },
    {
      "$ref": "#/$defs/SignalStateObservation"
    },
    {
      "$ref": "#/$defs/HeadingVsLaneObservation"
    },
    {
      "$ref": "#/$defs/StationaryObservation"
    },
    {
      "$ref": "#/$defs/RiderCountObservation"
    },
    {
      "$ref": "#/$defs/HelmetStateObservation"
