        },
        "confidence": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        },
        "is_inside": {
          "title": "Is Inside",
          "type": "boolean"
        },
        "obs_type": {
          "const": "in_zone",
          "default": "in_zone",
          "title": "Obs Type",
          "type": "string"
        },
        "observation_id": {
          "minLength": 1,
          "title": "Observation Id",
          "type": "string"
        },
        "producer": {
          "$ref": "#/$defs/Producer"
        },
        "timestamp": {
          "format": "date-time",
          "title": "Timestamp",
          "type": "string"
        },
        "track_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Track Id"
        },
        "zone_id": {
          "minLength": 1,
          "title": "Zone Id",
          "type": "string"
        },
        "zone_kind": {
          "$ref": "#/$defs/ZoneKind"
        }
      },
      "required": [
        "observation_id",
        "camera_id",
        "timestamp",
        "producer",
        "zone_id",
        "zone_kind",
        "is_inside"
      ],
      "title": "InZoneObservation",
      "type": "object"
    },
    "Producer": {
      "additionalProperties": false,
      "description": "Provenance for what produced an observation (model/heuristic/rule).",
      "properties": {
        "kind": {
          "$ref": "#/$defs/ProducerKind"
        },
        "name": {
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "name",
        "version",
        "kind"
      ],
      "title": "Producer",
      "type": "object"
    },
    "ProducerKind": {
      "description": "What kind of component produced an observation (provenance).",
      "enum": [
        "model",
        "heuristic",
        "rule",
        "tracker",
        "calibration"
      ],
      "title": "ProducerKind",
      "type": "string"
    },
    "RiderCountObservation": {
      "additionalProperties": false,
      "description": "Estimated rider count on a motorcycle (triple riding).",
      "properties": {
        "camera_id": {
          "minLength": 1,
